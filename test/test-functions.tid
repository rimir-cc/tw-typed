title: Output

\whitespace trim
\function _locate_rrt(type) [all[shadows+tiddlers]rrt.type<type>]
\function _locate-type-tiddler(type-key) [function[_locate_rrt],[type]key<type-key>]
\function _locate-field-tiddler(field-key, type-key) [function[_locate_rrt],[field]key<field-key>]:filter[<currentTiddler>get[validity]enlist-input[]match<type-key>]~[function[_locate_rrt],[field]key<field-key>!has[validity]]
\function _locate-enum-tiddler(enum-key, type-key) [function[_locate_rrt],[enum]key<enum-key>]
\function _calculate_selection(field-tid) [<field-tid>get[constraints]enlist-input[]match[n:1]then[single]]~[[multi]]
\function _get-blocking-min(field-key, type-key) [function[_locate-field-tiddler],<field-key>,<type-key>get[constraints]enlist-input[]prefix[!]suffix[+]first[]]:map[<currentTiddler>removeprefix[!]removesuffix[+]]

type:<$text text={{{ [function[_locate-type-tiddler],[mytype]] }}}/>,field:<$text text={{{ [function[_locate-field-tiddler],[myfield],[mytype]] }}}/>,enum:<$text text={{{ [function[_locate-enum-tiddler],[myenum],[mytype]] }}}/>,sel:<$text text={{{ [function[_calculate_selection],[FieldDef]] }}}/>,bmin:<$text text={{{ [function[_get-blocking-min],[myfield],[mytype]] }}}/>
